# ============================================================
# .env.example — Cantine SEBN
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer .env (voir .gitignore)
# ============================================================

# ------------------------------------------------------------
# ASP.NET Core
# ------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
# Production | Development | Staging
ASPNETCORE_URLS=http://localhost:5000

# ------------------------------------------------------------
# Base de données — SQL Server Express 2022
# ------------------------------------------------------------
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=CantineSEBN
DB_USER=sa
DB_PASSWORD=your_sqlserver_password_here
# Résultante utilisée dans appsettings.json :
# "Server=${DB_SERVER};Database=${DB_NAME};User Id=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True"

# ------------------------------------------------------------
# JWT — DOIT être identique au projet Node.js existant
# ------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_ISSUER=cantine-sebn
JWT_AUDIENCE=cantine-sebn-app
JWT_EXPIRATION_HOURS=8
# 8h = durée d'un shift (voir ARCHITECTURE.md)

# ------------------------------------------------------------
# Lecteurs biométriques Morpho Sigma Lite+
# ------------------------------------------------------------
MORPHO_TCP_PORT=22090
# Port à confirmer avec le fournisseur (probablement 22090)
# Format trame TCP : à confirmer (ASCII délimité ou binaire ?)

# ------------------------------------------------------------
# Imprimantes thermiques ESC/POS (réseau TCP)
# ------------------------------------------------------------
ESCPOS_PRINTER_PORT=9100
# Port Jetdirect standard — 1 imprimante par lecteur (IP configurée en base)
# Largeur papier : à confirmer (58 mm ou 80 mm)

# ------------------------------------------------------------
# Frontend React (Vite)
# ------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SSE_URL=http://localhost:5000/api/dashboard/stream

# ------------------------------------------------------------
# CORS — origines autorisées
# ------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://cantine.sebn.local

# ------------------------------------------------------------
# Export Excel
# ------------------------------------------------------------
EXCEL_MAX_ROWS=50000
# Limite de sécurité pour les exports ClosedXML streamés

# ------------------------------------------------------------
# Déploiement IIS (production)
# ------------------------------------------------------------
IIS_SITE_NAME=CantineSEBN
IIS_APP_POOL=CantineSEBNPool
IIS_PHYSICAL_PATH=C:\inetpub\wwwroot\cantine-sebn

# ------------------------------------------------------------
# Windows Service — TCP Listener
# ------------------------------------------------------------
SERVICE_NAME=CantineTcpService
SERVICE_DISPLAY_NAME=Cantine SEBN - TCP Listener
SERVICE_DESCRIPTION=Écoute les trames TCP des lecteurs Morpho Sigma Lite+

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
LOG_LEVEL=Information
# Trace | Debug | Information | Warning | Error | Critical
LOG_PATH=C:\Logs\CantineSEBN
